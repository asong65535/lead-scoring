# Lead Scoring Application Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# Application
# ============================================
ENVIRONMENT=development
DEBUG=true

# ============================================
# Database
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=lead_scoring

# ============================================
# CRM Configuration
# ============================================
# Set to "hubspot", "salesforce", or "none"
CRM_TYPE=none

# HubSpot (if CRM_TYPE=hubspot)
CRM_HUBSPOT_ACCESS_TOKEN=

# Salesforce (if CRM_TYPE=salesforce)
CRM_SALESFORCE_CLIENT_ID=
CRM_SALESFORCE_CLIENT_SECRET=
CRM_SALESFORCE_USERNAME=
CRM_SALESFORCE_PASSWORD=
CRM_SALESFORCE_SECURITY_TOKEN=
CRM_SALESFORCE_DOMAIN=login

# ============================================
# Model Configuration
# ============================================
MODEL_ARTIFACT_PATH=src/models/current.joblib
MODEL_VERSION=v0.0.0
MODEL_BUCKET_A_THRESHOLD=0.7
MODEL_BUCKET_B_THRESHOLD=0.4
MODEL_BUCKET_C_THRESHOLD=0.2
